# Copia este fichero a .env y ajústalo. docker compose lo lee automáticamente.

# Puerto del host (el contenedor escucha siempre en 8000 internamente)
PORT=8000

# REQUERIDO: clave de sesión, mínimo 32 caracteres
SECRET_KEY=cambia-esto-por-una-clave-de-32-o-mas-caracteres

# URL pública (para CORS / enlaces de email)
BASE_URL=http://127.0.0.1:8000
# Pon true solo si sirves por HTTPS (cookie Secure)
COOKIE_SECURE=false

# Código de registro (paridad con el origen)
REQUIRE_SIGNUP_CODE=false
SIGNUP_CODE=default

# Email (opcional; necesario para confirmación de cuenta y reset de contraseña)
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=

# Captcha reCAPTCHA Enterprise (opcional)
USE_CAPTCHA=false
CAPTCHA_BLOCK=false
CAPTCHA_KEY=
CAPTCHA_PROJECT_ID=
CAPTCHA_API_KEY=
